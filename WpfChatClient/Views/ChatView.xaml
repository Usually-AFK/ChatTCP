<UserControl x:Class="WpfChatClient.Views.ChatView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:vm="clr-namespace:WpfChatClient.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:ChatViewModel}"
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <Style x:Key="AvatarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="#5865F2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Ellipse Fill="{TemplateBinding Background}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FlatRowButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="RowBackground"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RowBackground" Property="Background" Value="#18FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="RowBackground" Property="Background" Value="#24FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ComposerIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrightGlassBorder}"/>
            <Setter Property="Background" Value="#D9FFFFFF"/>
            <Setter Property="Foreground" Value="{StaticResource BrightTextPrimary}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#F2FFFFFF"/>
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource LiquidAccent}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ChannelItemStyle" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{StaticResource BrightTextSecondary}"/>
            <Setter Property="Padding" Value="10,9"/>
            <Setter Property="Margin" Value="0,3"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform X="0"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ChannelChrome"
                                Background="Transparent"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ChannelChrome" Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ChannelChrome" Property="Background" Value="{StaticResource LiquidAccentSoft}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                             To="4"
                                             Duration="0:0:0.12"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                             To="0"
                                             Duration="0:0:0.12"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MessageItemContainerStyle" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="ToastTemplate">
            <Border Width="320"
                    Margin="0,0,0,10"
                    Padding="14"
                    Background="#DD20242A"
                    BorderBrush="{StaticResource GlassBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Opacity="0">
                <Border.RenderTransform>
                    <TranslateTransform Y="-10"/>
                </Border.RenderTransform>
                <Border.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.16"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                 To="0"
                                                 Duration="0:0:0.16"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Border.Triggers>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Title}"
                                       Foreground="{StaticResource BrightTextPrimary}"
                                       FontWeight="SemiBold"
                                       FontSize="13"/>
                            <TextBlock Text="{Binding Time}"
                                       Foreground="{StaticResource BrightTextSecondary}"
                                       FontSize="11"
                                       Margin="8,1,0,0"/>
                        </StackPanel>
                        <TextBlock Text="{Binding Message}"
                                   Foreground="{StaticResource BrightTextSecondary}"
                                   TextWrapping="Wrap"
                                   FontSize="12"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="1"
                            Content="x"
                            Width="24"
                            Height="24"
                            Margin="8,-4,-4,0"
                            Foreground="{StaticResource BrightTextSecondary}"
                            Style="{StaticResource FlatRowButtonStyle}"
                            Command="{Binding DataContext.DismissToastCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                            CommandParameter="{Binding Id}"/>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="TransferTemplate">
            <Border Margin="0,0,0,8"
                    Padding="12"
                    Background="#CC20242A"
                    BorderBrush="{StaticResource GlassBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{Binding FileName}"
                                   Foreground="{StaticResource BrightTextPrimary}"
                                   FontWeight="SemiBold"
                                   FontSize="12"/>
                        <TextBlock Text="{Binding StatusText}"
                                   Foreground="{StaticResource BrightTextSecondary}"
                                   FontSize="11"
                                   Margin="0,2,0,6"/>
                        <ProgressBar Minimum="0"
                                     Maximum="100"
                                     Height="6"
                                     Value="{Binding ProgressPercent, Mode=OneWay}"
                                     Foreground="{StaticResource LiquidAccent}"/>
                    </StackPanel>
                    <Button Grid.Column="1"
                            Content="Cancel"
                            Margin="12,0,0,0"
                            Padding="8,4"
                            Style="{StaticResource FlatRowButtonStyle}"
                            Command="{Binding DataContext.CancelFileTransferCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                            CommandParameter="{Binding TransferKey}"
                            IsEnabled="{Binding CanCancel}"/>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="RoomFileTemplate">
            <Border Margin="0,0,0,8"
                    Padding="12"
                    Background="#EEF6FF"
                    BorderBrush="#D2E6FF"
                    BorderThickness="1"
                    CornerRadius="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{Binding FileName}"
                                   Foreground="#1E293B"
                                   FontWeight="SemiBold"
                                   FontSize="12"/>
                        <TextBlock Text="{Binding FileSizeLabel}"
                                   Foreground="#475569"
                                   FontSize="11"
                                   Margin="0,2,0,0"/>
                        <TextBlock Text="{Binding UploadedBy, StringFormat=By {0}}"
                                   Foreground="#64748B"
                                   FontSize="10"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="1"
                            Content="Download"
                            Margin="12,0,0,0"
                            Padding="8,4"
                            Style="{StaticResource FlatRowButtonStyle}"
                            Foreground="#0F172A"
                            Command="{Binding DataContext.DownloadRoomFileCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                            CommandParameter="{Binding}"/>
                </Grid>
            </Border>
        </DataTemplate>

        <Storyboard x:Key="ExpandSidebar">
            <DoubleAnimation Storyboard.TargetProperty="Width"
                             To="240"
                             Duration="0:0:0.6">
                <DoubleAnimation.EasingFunction>
                    <ElasticEase Oscillations="1" Springiness="5" EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             To="1"
                             Duration="0:0:0.2"/>
        </Storyboard>

        <Storyboard x:Key="CollapseSidebar">
            <DoubleAnimation Storyboard.TargetProperty="Width"
                             To="10"
                             Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             To="0.2"
                             Duration="0:0:0.25"/>
        </Storyboard>
    </UserControl.Resources>

    <Grid x:Name="ChatRoot" Background="{StaticResource LiquidGlassBackground}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Width="72"
                Margin="16"
                Opacity="1"
                Background="{StaticResource BrightGlassSoft}"
                BorderBrush="{StaticResource BrightGlassBorder}"
                BorderThickness="1"
                CornerRadius="28">
            <Border.Triggers>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard Storyboard="{StaticResource ExpandSidebar}"/>
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard Storyboard="{StaticResource CollapseSidebar}"/>
                </EventTrigger>
            </Border.Triggers>
            <StackPanel Margin="8,16">
                <ui:Button Margin="4,6" Width="48" Height="48" CornerRadius="24" Content="H"/>
                <Separator Background="#22FFFFFF" Margin="20,5"/>
                <ui:Button Margin="4,6" Width="48" Height="48" CornerRadius="24" Content="S1"/>
                <ui:Button Margin="4,6" Width="48" Height="48" CornerRadius="24" Content="S2"/>
            </StackPanel>
        </Border>

        <Border Grid.Column="1"
                Margin="0,16,10,16"
                Padding="0"
                Style="{StaticResource LiquidGlassPanel}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Height="48" BorderBrush="{StaticResource GlassBorderBrush}" BorderThickness="0,0,0,1">
                    <TextBlock Text="WPF CHAT" VerticalAlignment="Center" Margin="16,0" FontWeight="Bold" Foreground="{StaticResource BrightTextPrimary}"/>
                </Border>
                <StackPanel Grid.Row="1" Margin="8,16">
                    <TextBlock Text="TEXT CHANNELS" Foreground="{StaticResource BrightTextSecondary}" FontSize="12" FontWeight="Bold" Margin="8,0,0,8"/>
                    <ListBox Background="Transparent"
                             BorderThickness="0"
                             ItemContainerStyle="{StaticResource ChannelItemStyle}"
                             ItemsSource="{Binding Rooms}"
                             SelectedItem="{Binding SelectedRoom, Mode=TwoWay}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="#"
                                               Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}"
                                               FontWeight="Bold"
                                               Margin="0,0,8,0"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Id}"
                                               Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}"/>
                                    <Border Grid.Column="2"
                                            Background="#FF6B6B"
                                            CornerRadius="10"
                                            Padding="6,2"
                                            Margin="8,0,0,0"
                                            Visibility="{Binding HasUnread, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <TextBlock Text="{Binding UnreadCount}"
                                                   Foreground="White"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"/>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="2" Margin="0,16" Background="Transparent">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <ItemsControl Grid.Row="0"
                              ItemsSource="{Binding Transfers}"
                              ItemTemplate="{StaticResource TransferTemplate}"
                              Margin="20,8,20,0"/>

                <ListBox x:Name="MessagesListBox"
                         Grid.Row="1"
                         ItemsSource="{Binding Messages}"
                         Background="Transparent"
                         BorderThickness="0"
                         Padding="20,8,20,12"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.CanContentScroll="True"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling"
                         VirtualizingPanel.CacheLength="1"
                         VirtualizingPanel.CacheLengthUnit="Page"
                         ItemContainerStyle="{StaticResource MessageItemContainerStyle}">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,16" Opacity="0">
                            <Grid.RenderTransform>
                                <TranslateTransform Y="8"/>
                            </Grid.RenderTransform>
                            <Grid.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.16"/>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                             To="0"
                                                             Duration="0:0:0.16"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Grid.Triggers>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0"
                                    Background="{Binding AvatarColor}"
                                    Margin="0,0,12,0"
                                    VerticalAlignment="Top"
                                    Command="{Binding DataContext.ShowProfileCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                    CommandParameter="{Binding Sender}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource AvatarButtonStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsOwn}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <Border x:Name="MessageBorder" Grid.Column="1" Padding="12,10">
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource BrightGlassCard}">
                                        <Setter Property="HorizontalAlignment" Value="Left"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsOwn}" Value="True">
                                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                                <Setter Property="Background" Value="{StaticResource LiquidOwnBubble}"/>
                                                <Setter Property="BorderBrush" Value="#AA7C8CFF"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsSticker}" Value="True">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="BorderBrush" Value="Transparent"/>
                                                <Setter Property="Padding" Value="0"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <TextBlock FontWeight="Bold" FontSize="14" VerticalAlignment="Bottom">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="{Binding Sender}"/>
                                                    <Setter Property="Foreground" Value="{StaticResource BrightTextPrimary}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsOwn}" Value="True">
                                                            <Setter Property="Text" Value="You"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="{Binding Time}"
                                                   Foreground="{StaticResource BrightTextSecondary}"
                                                   FontSize="11"
                                                   Margin="8,0,0,1"
                                                   VerticalAlignment="Bottom"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Content}"
                                               Foreground="{StaticResource BrightTextPrimary}"
                                               TextWrapping="Wrap"
                                               FontSize="14"
                                               LineHeight="20">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSticker}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <Border Width="126"
                                            MinHeight="118"
                                            Padding="12"
                                            CornerRadius="22"
                                            BorderThickness="2"
                                            BorderBrush="{Binding StickerAccentColor}"
                                            Effect="{x:Null}">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Setter Property="Background" Value="#F2FFFFFF"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSticker}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding StickerGlyph}"
                                                       FontFamily="Segoe UI Emoji"
                                                       FontSize="46"
                                                       TextAlignment="Center"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding StickerName}"
                                                       Foreground="{Binding StickerAccentColor}"
                                                       FontWeight="SemiBold"
                                                       FontSize="12"
                                                       Margin="0,6,0,0"
                                                       TextAlignment="Center"
                                                       HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>

            <ItemsControl Grid.Row="0"
                          ItemsSource="{Binding Toasts}"
                          ItemTemplate="{StaticResource ToastTemplate}"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Top"
                          Margin="0,16,16,0"
                          Panel.ZIndex="5"/>

            <Popup IsOpen="{Binding IsStickerPickerOpen, Mode=TwoWay}"
                   Placement="Top"
                   PlacementTarget="{Binding ElementName=ComposerPanel}"
                   AllowsTransparency="True"
                   StaysOpen="False"
                   DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
                   Panel.ZIndex="6">
                <Border Width="318"
                        Padding="12"
                        Background="{StaticResource BrightGlassPanel}"
                        BorderBrush="{StaticResource BrightGlassBorder}"
                        BorderThickness="1"
                        CornerRadius="18">
                    <StackPanel>
                        <TextBlock Text="STICKERS"
                                   Foreground="{StaticResource BrightTextSecondary}"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   Margin="2,0,0,8"/>
                        <ItemsControl ItemsSource="{Binding Stickers}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="3"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Margin="4"
                                            Padding="0"
                                            Style="{StaticResource FlatRowButtonStyle}"
                                            Command="{Binding DataContext.SendStickerCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding Id}">
                                        <Border Width="86"
                                                Height="80"
                                                Padding="8"
                                                Background="#F2FFFFFF"
                                                BorderBrush="{Binding AccentColor}"
                                                BorderThickness="1.5"
                                                CornerRadius="18">
                                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Glyph}"
                                                           FontFamily="Segoe UI Emoji"
                                                           FontSize="28"
                                                           HorizontalAlignment="Center"/>
                                                <TextBlock Text="{Binding DisplayName}"
                                                           Foreground="{Binding AccentColor}"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Margin="0,4,0,0"
                                                           HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Popup>

            <Border x:Name="ComposerPanel"
                    Grid.Row="1"
                    Margin="20,0,20,20"
                    Padding="12"
                    Style="{StaticResource LiquidGlassPanel}">
                <StackPanel>
                    <TextBlock Text="{Binding TypingStatus}"
                               Foreground="{StaticResource BrightTextSecondary}"
                               FontSize="11"
                               Margin="4,0,0,4"
                               Visibility="{Binding IsSomeoneTyping, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <ui:TextBox Grid.Column="0"
                                    Text="{Binding MessageText, UpdateSourceTrigger=PropertyChanged}"
                                    Style="{StaticResource BrightGlassTextBox}"
                                    PlaceholderText="{Binding CurrentRoomId, StringFormat=Message #{0}}"
                                    Margin="0,0,8,0"
                                    Height="44"
                                    IsEnabled="{Binding IsConnected}">
                            <ui:TextBox.InputBindings>
                                <KeyBinding Key="Enter" Command="{Binding SendMessageCommand}"/>
                            </ui:TextBox.InputBindings>
                        </ui:TextBox>

                        <Button Grid.Column="1"
                                Style="{StaticResource ComposerIconButtonStyle}"
                                Margin="0,0,8,0"
                                ToolTip="Insert quick emoji"
                                Command="{Binding InsertQuickEmojiCommand}"
                                IsEnabled="{Binding IsConnected}">
                            <TextBlock Text="&#x263A;" FontSize="18"/>
                        </Button>

                        <Button Grid.Column="2"
                                Style="{StaticResource ComposerIconButtonStyle}"
                                Margin="0,0,8,0"
                                ToolTip="Open stickers"
                                Command="{Binding ToggleStickerPickerCommand}"
                                IsEnabled="{Binding IsConnected}">
                            <TextBlock Text="&#x2726;" FontSize="18"/>
                        </Button>

                        <Button Grid.Column="3"
                                Style="{StaticResource ComposerIconButtonStyle}"
                                Margin="0,0,8,0"
                                ToolTip="Send file"
                                Command="{Binding SendFileCommand}"
                                IsEnabled="{Binding IsConnected}">
                            <TextBlock Text="&#x1F4CE;" FontSize="16"/>
                        </Button>

                        <ui:Button Grid.Column="4"
                                   Content="Send"
                                   Command="{Binding SendMessageCommand}"
                                   Style="{StaticResource ModernButton}"
                                   Width="80"
                                   Height="44"
                                   IsEnabled="{Binding IsConnected}"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Column="3"
                Width="236"
                Margin="10,16,16,16"
                Opacity="1"
                Style="{StaticResource LiquidGlassPanel}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="{Binding OnlineHeader}" Foreground="{StaticResource BrightTextSecondary}" FontSize="11" FontWeight="Bold" Margin="16,20,16,10"/>

                <ListBox Grid.Row="1" ItemsSource="{Binding Users}" Background="Transparent" BorderThickness="0" Padding="8">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Button Style="{StaticResource FlatRowButtonStyle}"
                                    Command="{Binding DataContext.ShowProfileCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                    CommandParameter="{Binding Name}">
                                <StackPanel Orientation="Horizontal" Margin="8,4">
                                    <Grid Width="32" Height="32" Margin="0,0,12,0">
                                        <Ellipse Fill="{Binding Color}"/>
                                        <Ellipse Width="9"
                                                 Height="9"
                                                 Fill="#22C55E"
                                                 Stroke="#20242A"
                                                 StrokeThickness="2"
                                                 HorizontalAlignment="Right"
                                                 VerticalAlignment="Bottom"/>
                                    </Grid>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center" Foreground="{StaticResource BrightTextPrimary}" FontSize="14"/>
                                        <TextBlock Text="{Binding Status}" Foreground="{StaticResource BrightTextSecondary}" FontSize="11"/>
                                    </StackPanel>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <StackPanel Grid.Row="2" Margin="12,0,12,12">
                    <TextBlock Text="FILES"
                               Foreground="{StaticResource BrightTextSecondary}"
                               FontSize="11"
                               FontWeight="Bold"
                               Margin="4,8,0,6"/>
                    <ScrollViewer MaxHeight="220" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding RoomFiles}"
                                      ItemTemplate="{StaticResource RoomFileTemplate}"/>
                    </ScrollViewer>
                </StackPanel>
            </Grid>
        </Border>

        <Popup IsOpen="{Binding IsProfileCardOpen, Mode=TwoWay}"
               Placement="MousePoint"
               AllowsTransparency="True"
               StaysOpen="False"
               PlacementTarget="{Binding ElementName=ChatRoot}"
               DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
            <Border Width="260"
                    Padding="16"
                    Background="{StaticResource BrightGlassPanel}"
                    BorderBrush="{StaticResource GlassBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="20"
                    Opacity="0">
                <Border.RenderTransform>
                    <ScaleTransform ScaleX="0.96" ScaleY="0.96"/>
                </Border.RenderTransform>
                <Border.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.14"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.14"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.14"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Border.Triggers>
                <Grid DataContext="{Binding SelectedProfile}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="48" Height="48" Fill="{Binding AvatarColor}" Margin="0,0,12,0"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding Name}" Foreground="{StaticResource BrightTextPrimary}" FontWeight="SemiBold" FontSize="16"/>
                            <TextBlock Text="{Binding Status}" Foreground="{StaticResource BrightTextSecondary}" FontSize="12" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>
                    <TextBlock Grid.Row="1"
                               Text="Global chat member"
                               Foreground="{StaticResource BrightTextSecondary}"
                               FontSize="12"
                               Margin="0,14,0,0"/>
                </Grid>
            </Border>
        </Popup>
    </Grid>
</UserControl>
