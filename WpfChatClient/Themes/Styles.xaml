<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

    <!-- GlassCard Style -->
    <Style x:Key="GlassCard" TargetType="Border">
        <Setter Property="Background" Value="#2AFFFFFF" />
        <Setter Property="BorderBrush" Value="#11FFFFFF" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="15" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="20" ShadowDepth="0" Color="Black" Opacity="0.3" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- GlassTextBox Style -->
    <Style x:Key="GlassTextBox" TargetType="ui:TextBox" BasedOn="{StaticResource {x:Type ui:TextBox}}">
        <Setter Property="Background" Value="#40000000" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="BorderBrush" Value="#22FFFFFF" />
        <Setter Property="Padding" Value="8,4" />
    </Style>

    <!-- ModernButton Style -->
    <Style x:Key="ModernButton" TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
        <Setter Property="Background" Value="#5865F2" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="BorderThickness" Value="0" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#4752C4" />
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>
